NEXT_PUBLIC_SITE_URL=https://danssmokereview.vercel.app

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional: comma-separated Supabase auth user UUIDs allowed to edit (empty = any signed-in user)
SUPABASE_ADMIN_USER_IDS=

# Beehiiv — Michigan Smoke Scoreboard newsletter (server-only; never expose in client bundles)
BEEHIIV_API_KEY=
# Use v2 prefixed ID (pub_…) — bare UUID also works: bf9d77dd-f673-4ce1-b7b7-d56897917f08
BEEHIIV_PUBLICATION_ID=pub_bf9d77dd-f673-4ce1-b7b7-d56897917f08
